# ============================================================================
# Научный клубок / Science-Ball — environment template.
# Copy to `.env` and fill secrets. NEVER commit a real `.env`.
# The system runs in the EMBEDDED profile by default (no Docker needed).
# ============================================================================

APP_ENV=local
LOG_LEVEL=INFO
# embedded = Kuzu + qdrant-local + BM25 (default, runs anywhere);
# server   = Neo4j + Qdrant + OpenSearch via docker compose.
RUNTIME_PROFILE=embedded
RUNTIME_DIR=./var

# ---- LLM / embeddings (OSS-ONLY, OpenRouter) -------------------------------
# Per hackathon rules only OSS-licensed models are allowed (Apache-2.0 / MIT).
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL_EXTRACT=qwen/qwen-2.5-7b-instruct          # Apache-2.0
LLM_MODEL_SYNTH=deepseek/deepseek-chat-v3-0324       # MIT
LLM_MODEL_FAST=qwen/qwen-2.5-7b-instruct             # Apache-2.0
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=3
LLM_TIMEOUT_S=90
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  # Apache-2.0
EMBEDDING_DIM=384

# ---- Embedded store paths --------------------------------------------------
KUZU_DB_PATH=./var/kuzu/graph
QDRANT_PATH=./var/qdrant
QDRANT_COLLECTION=kg_chunks
QDRANT_ENTITY_COLLECTION=kg_entities
BM25_PATH=./var/bm25
DATA_DIR=./data
UPLOADS_DIR=./var/uploads
ARTIFACTS_DIR=./var/artifacts

# ---- Server-profile services (docker compose §13.1) ------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
QDRANT_URL=http://localhost:6333
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=adminadminadmin
POSTGRES_DSN=postgresql://kg:kg@localhost:5432/kg_app
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET=kg-documents
DOCLING_SERVE_URL=http://localhost:5001
DAGSTER_URL=http://localhost:3001

# ---- Ports (§13.1): frontend 3000, api 8000, agent 8010, ingestion 8020,
#      docling 5001, neo4j 7474/7687, qdrant 6333/6334, opensearch 9200,
#      postgres 5432, redis 6379, minio 9000/9001, dagster 3001 ----

# ---- Observability ---------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
MLFLOW_TRACKING_URI=
LANGSMITH_API_KEY=

# ---- Auth ------------------------------------------------------------------
JWT_SECRET=dev-insecure-change-me
JWT_TTL_MINUTES=720
